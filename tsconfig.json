{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2024",
        "moduleResolution": "bundler",
        "paths": {},
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "strict": false,
        "rootDir": "./src",
        "types": [
            "bun-types"
        ]
    },
    "include": [
        "./src"
    ],
    "exclude": [
        "node_modules",
        "src/generate-static.ts"
    ],
    "tsc-alias": {
        "resolveFullPaths": true,
        "verbose": false
    }
}
